# Local .terraform directories
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files by default (likely to contain sensitive data)
*.tfvars
*.tfvars.json

# Allow specific environment variable files needed for CI/CD
!dev.tfvars
!prod.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Archives and build artifacts
*.zip

# Personal notes & documentation draft
connaissances.txt